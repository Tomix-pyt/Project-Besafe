import joblib
from fastapi import FastAPI
from pydantic import BaseModel

# 1. Define your input data structure
class PredictionInput(BaseModel):
    feature1: float
    feature2: float
    feature3: float

# 2. Initialize FastAPI
app = FastAPI(title="AI Model API")

# Global variable for the model
model = None

# 3. Load model on startup to save memory and time
@app.on_event("startup")
def load_model():
    global model
    # Replace 'model.pkl' with your actual filename
    model = joblib.load("model.pkl") 

@app.get("/")
def home():
    return {"status": "Online", "message": "Visit /docs for interactive testing"}

# 4. Create the prediction endpoint
@app.post("/predict")
def predict(data: PredictionInput):
    # Convert Pydantic model to a format for the ML model (e.g., list or dict)
    input_features = [[data.feature1, data.feature2, data.feature3]]
    prediction = model.predict(input_features)
    
    return {
        "prediction": prediction.tolist(),
        "input_received": data.dict()
    }

# 5. Run with Uvicorn (optional, can also run from terminal)
if __name__ == "__main__":
    import uvicorn
    uvicorn.run(app, host="0.0.0.0", port=8000)
